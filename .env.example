APP_CONFIG_ENCRYPTION_KEY=replace-with-fernet-or-long-random-string
JWT_SIGNING_KEY=replace-with-long-random-jwt-secret
DATABASE_URL=sqlite:////data/pt_media_hub.db
ENVIRONMENT=production
CORS_ORIGINS=http://localhost:8000
SNAPSHOT_INTERVAL_MINUTES=10
QB2_GRANT_MINUTES=15

# Optional fallback for NAS deployments. Settings page values take priority.
TMDB_MODE=direct
TMDB_GATEWAY_URL=
TMDB_GATEWAY_KEY=

# Optional NAS/download directories mounted into the backend container.
# Fill the left side with real NAS paths, then use /mnt/storage1 etc. in downloader settings.
MEDIA_HUB_STORAGE_1=./data
MEDIA_HUB_STORAGE_2=./data
MEDIA_HUB_STORAGE_3=./data
